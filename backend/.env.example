# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/creators_factory

# Auth
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ACCESS_COOKIE_NAME=auth_token
REFRESH_COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000

# S3 / MinIO (optional)
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=creators-factory
PUBLIC_MEDIA_BASE_URL=http://localhost:9000/creators-factory

# fal.ai API
FAL_API_KEY=

# Local media fallback (used when S3 is not configured)
LOCAL_MEDIA_BASE_URL=http://localhost:8000/media
LOCAL_MEDIA_ROOT=./media
